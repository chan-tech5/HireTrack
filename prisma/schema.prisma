// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  RECRUITER
  INTERVIEWER
}

enum JobStatus {
  DRAFT
  OPEN
  PAUSED
  CLOSED
  ARCHIVED
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  FREELANCE
}

enum WorkMode {
  ONSITE
  REMOTE
  HYBRID
}

enum ApplicationStage {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  HIRED
  REJECTED
  WITHDRAWN
}

enum InterviewType {
  PHONE_SCREENING
  TECHNICAL
  HR
  CULTURAL_FIT
  FINAL
  PANEL
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  RESCHEDULED
  NO_SHOW
}

enum NotificationType {
  APPLICATION_RECEIVED
  STAGE_CHANGED
  INTERVIEW_SCHEDULED
  INTERVIEW_REMINDER
  OFFER_SENT
  CANDIDATE_HIRED
  CANDIDATE_REJECTED
  SYSTEM
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Organization {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  logoUrl   String?
  website   String?
  industry  String?
  size      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users User[]
  jobs  Job[]

  @@map("organizations")
}

model User {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  emailVerified  DateTime?
  hashedPassword String?
  image          String?
  role           Role      @default(RECRUITER)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  accounts           Account[]
  sessions           Session[]
  createdJobs        Job[]           @relation("CreatedBy")
  assignedInterviews Interview[]     @relation("Interviewer")
  notifications      Notification[]
  activityLogs       ActivityLog[]

  @@index([organizationId])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Job {
  id               String    @id @default(cuid())
  title            String
  slug             String    @unique
  description      String    @db.Text
  requirements     String?   @db.Text
  responsibilities String?   @db.Text
  department       String?
  location         String?
  workMode         WorkMode  @default(ONSITE)
  type             JobType   @default(FULL_TIME)
  status           JobStatus @default(DRAFT)
  salaryMin        Int?
  salaryMax        Int?
  currency         String?   @default("USD")
  openings         Int       @default(1)
  experienceMin    Int?
  experienceMax    Int?
  skills           String[]
  closingDate      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdById    String
  createdBy      User         @relation("CreatedBy", fields: [createdById], references: [id])

  applications Application[]

  @@index([organizationId, status])
  @@index([slug])
  @@map("jobs")
}

model Candidate {
  id              String    @id @default(cuid())
  firstName       String
  lastName        String
  email           String    @unique
  phone           String?
  avatarUrl       String?
  resumeUrl       String?
  resumeFileName  String?
  linkedinUrl     String?
  portfolioUrl    String?
  currentTitle    String?
  currentCompany  String?
  currentLocation String?
  experienceYears Int?
  skills          String[]
  source          String?
  tags            String[]
  notes           String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  applications Application[]

  @@index([email])
  @@map("candidates")
}

model Application {
  id             String           @id @default(cuid())
  stage          ApplicationStage @default(APPLIED)
  coverLetter    String?          @db.Text
  expectedSalary Int?
  noticePeriod   Int?
  appliedAt      DateTime         @default(now())
  stageChangedAt DateTime         @default(now())
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?

  jobId       String
  job         Job       @relation(fields: [jobId], references: [id])
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id])

  interviews   Interview[]
  notes        ApplicationNote[]
  stageHistory StageHistory[]

  @@unique([jobId, candidateId])
  @@index([jobId, stage])
  @@index([candidateId])
  @@map("applications")
}

model StageHistory {
  id        String            @id @default(cuid())
  fromStage ApplicationStage?
  toStage   ApplicationStage
  changedAt DateTime          @default(now())
  reason    String?

  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("stage_history")
}

model ApplicationNote {
  id        String   @id @default(cuid())
  content   String   @db.Text
  isPrivate Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("application_notes")
}

model Interview {
  id              String          @id @default(cuid())
  title           String
  type            InterviewType   @default(TECHNICAL)
  status          InterviewStatus @default(SCHEDULED)
  scheduledAt     DateTime
  durationMinutes Int             @default(60)
  meetingLink     String?
  location        String?
  notes           String?         @db.Text
  feedback        String?         @db.Text
  rating          Int?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  interviewers  User[]      @relation("Interviewer")
  scorecard     Scorecard?

  @@index([applicationId])
  @@index([scheduledAt])
  @@map("interviews")
}

model Scorecard {
  id             String   @id @default(cuid())
  overallRating  Int
  recommendation String
  criteria       Json
  summary        String?  @db.Text
  submittedAt    DateTime @default(now())

  interviewId String    @unique
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@map("scorecards")
}

model Notification {
  id         String           @id @default(cuid())
  type       NotificationType
  title      String
  message    String
  isRead     Boolean          @default(false)
  entityId   String?
  entityType String?
  createdAt  DateTime         @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model ActivityLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@map("activity_logs")
}
